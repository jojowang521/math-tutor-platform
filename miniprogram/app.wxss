page {
  background: #f7f2ea;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.hero {
  background: linear-gradient(135deg, #172033 0%, #2563eb 100%);
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  color: #ffffff;
}

.eyebrow {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(250, 204, 21, 0.18);
  color: #fde68a;
  font-size: 24rpx;
  font-weight: 700;
}

.h1 {
  display: block;
  margin-top: 24rpx;
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 800;
}

.muted {
  color: #6b7280;
  font-size: 26rpx;
  line-height: 40rpx;
}

.hero .muted {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.84);
}

.section-title {
  display: block;
  margin: 34rpx 0 18rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.card {
  background: #fffdf8;
  border: 1rpx solid #ded4c5;
  border-radius: 16rpx;
  padding: 26rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
}

.card-title {
  display: block;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 800;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #3730a3;
  font-size: 22rpx;
  font-weight: 700;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.primary-btn {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.secondary-btn {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1f2933;
  border: 1rpx solid #ded4c5;
  font-size: 28rpx;
}
