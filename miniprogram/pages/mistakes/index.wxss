.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx solid #ded4c5;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 28rpx;
}

.input {
  height: 80rpx;
}

.textarea {
  min-height: 180rpx;
  line-height: 40rpx;
}

.primary-btn {
  margin-top: 20rpx;
}

.mistake-text {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 42rpx;
}
