.meta {
  display: flex;
  gap: 12rpx;
  margin: 18rpx 0;
}

.test-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #ded4c5;
}

.question {
  margin: 14rpx 0;
  color: #1f2933;
  font-size: 28rpx;
  line-height: 42rpx;
}

.answer {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f0fdf4;
  color: #15803d;
  font-size: 26rpx;
  line-height: 40rpx;
}
